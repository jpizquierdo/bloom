# Copy to .env and adjust for your environment.

# Database (matches docker/docker-compose.yml)
DATABASE_URL=postgresql+psycopg://bloom:bloom@localhost:5432/bloom

# JWT / auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# First admin, created on startup if it does not exist. Leave blank to skip.
BLOOM_ADMIN_EMAIL=
BLOOM_ADMIN_PASSWORD=
