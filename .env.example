# Copy to .env and adjust for your environment.

# Database (matches docker/docker-compose.yml)
POSTGRES_USER=bloom
POSTGRES_PASSWORD=bloom
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bloom

# JWT / auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# How long a password-reset link stays valid.
RESET_TOKEN_EXPIRE_MINUTES=30

# Outgoing mail (password resets, new-account invites). Leave SMTP_HOST blank to disable
# sending: links are logged instead. The dev docker-compose ships Mailpit on port 1025,
# with a web UI at http://localhost:8025.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# STARTTLS on a submission port (587). Use SMTP_SSL=true for implicit TLS (465) instead.
SMTP_TLS=true
SMTP_SSL=false
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=Bloom

# Logging
LOG_LEVEL=INFO

# Browser clients allowed to call the API (CORS). FRONTEND_HOST is always allowed;
# BACKEND_CORS_ORIGINS is a comma-separated list of extra origins.
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS=

# First admin, created on startup if it does not exist. Leave blank to skip.
BLOOM_ADMIN_EMAIL=
BLOOM_ADMIN_PASSWORD=
