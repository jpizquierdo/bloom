# Copy to .env and adjust for your environment.

# Database (matches docker/docker-compose.yml)
POSTGRES_USER=bloom
POSTGRES_PASSWORD=bloom
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bloom

# JWT / auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Logging
LOG_LEVEL=INFO

# First admin, created on startup if it does not exist. Leave blank to skip.
BLOOM_ADMIN_EMAIL=
BLOOM_ADMIN_PASSWORD=
